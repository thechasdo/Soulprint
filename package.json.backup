{
  "name": "soulprint-platform",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "security:audit": "npm audit --audit-level=moderate",
    "db:push": "supabase db push",
    "functions:deploy": "supabase functions deploy create-checkout-session && supabase functions deploy stripe-webhook && supabase functions deploy index-asset"
  },
  "dependencies": {
    "@supabase/ssr": "latest",
    "@supabase/supabase-js": "latest",
    "clsx": "latest",
    "lucide-react": "latest",
    "next": "^9.3.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "stripe": "latest"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "latest",
    "eslint": "latest",
    "eslint-config-next": "^16.2.7",
    "postcss": "latest",
    "supabase": "^2.105.0",
    "tailwindcss": "latest",
    "typescript": "latest"
  },
  "allowScripts": {
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  }
}
