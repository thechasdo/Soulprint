STRIPE_PRICE_FOREVER_ARCHIVE_MONTHLY=price_your_forever_archive_monthly
STRIPE_PRICE_FOREVER_ARCHIVE_YEARLY=price_your_forever_archive_yearly

# Stripe recurring add-on prices
